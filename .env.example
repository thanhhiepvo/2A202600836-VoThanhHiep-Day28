# Copy to .env and fill in your values:
#   cp .env.example .env

# Kaggle vLLM tunnel URL (ngrok or cloudflared)
VLLM_NGROK_URL=https://your-vllm-tunnel.ngrok-free.app
VLLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# Kaggle embedding service tunnel URL
EMBED_NGROK_URL=https://your-embed-tunnel.ngrok-free.app

# LangSmith (https://smith.langchain.com) — optional but recommended for Integration 10
LANGCHAIN_API_KEY=lsv2_pt_your_key_here
LANGCHAIN_PROJECT=lab28-platform

# Set to 1 to use local sentence-transformers instead of Kaggle embedding service
LOCAL_EMBED=0

# Set to 1 for local smoke tests without Kaggle (disable before final submission demo)
MOCK_VLLM=0
